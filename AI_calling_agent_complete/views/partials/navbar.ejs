<nav>
    <div class="logo" onclick="window.location.href='/'">AI Call Agent</div>
    
    <div class="hamburger" onclick="toggleMenu()">
        <span>&#9776;</span>
    </div>

    <ul class="menu" id="mobileMenu">
        <li><a href="/">Home</a></li>
        <li><a href="/generator">Generate</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/pricing">Pricing</a></li>
        <li><a href="/about">About</a></li>
        <% if(user && user.role === 'admin') { %>
            <li><a href="/admin" class="nav-admin-link">Admin</a></li>
            <li><a href="/sales" class="nav-admin-link" style="color: var(--color-primary);">Sales</a></li>
        <% } %>
        
        <!-- Mobile-only Auth Links -->
        <li class="mobile-only">
            <% if(user) { %>
                <a href="/profile">Profile (<%= user.name %>)</a>
                <a href="/favorites">Favorites</a>
                <% if(user.role === 'admin') { %>
                    <a href="/admin">Admin Dashboard</a>
                <% } %>
                <a href="/logout" class="nav-logout-link">Logout</a>
            <% } else { %>
                <a href="/login">Login</a>
                <a href="/signup">Sign Up</a>
            <% } %>
        </li>
    </ul>

    <div class="auth-buttons">
        <% if(user) { %>
            <a href="/favorites" class="user-profile-nav nav-fav-link" title="My Favorites">
                <svg viewBox="0 0 24 24" class="nav-heart-icon"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            </a>
            <a href="/profile" class="user-profile-nav">
                <span><%= user.name %></span>
                <% if(user.role === 'admin') { %><span class="admin-badge">Admin</span><% } %>
                <img src="<%= user.avatar || '/uploads/default-avatar.png' %>" alt="Profile">
            </a>
            <a href="/logout" class="signup-btn">Logout</a>
        <% } else { %>
            <a href="/login" class="login-btn">Login</a>
            <a href="/signup" class="signup-btn">Sign Up</a>
        <% } %>
    </div>
</nav>

<script>
    function toggleMenu() {
        const menu = document.getElementById('mobileMenu');
        menu.classList.toggle('active');
    }
</script>
