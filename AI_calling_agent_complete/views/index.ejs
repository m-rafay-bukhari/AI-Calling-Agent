<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Call Agent </title>    
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/home.css">
<!---Font-  Poppins- -->

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('partials/navbar') %>

    <!---hero section--->

    <section class ="hero">
        <h1>Automate Your Customer Calls</h1>
        <p>Generate AI-powered call scripts for lead generation, appointment setting, and customer support. 
            Scale your business instantly.</p>
        <a href="/generator"><button>Start Generating Scripts</button></a>
    </section>

    <div class="container">
        <!-- How It Works -->
        <h2 class="section-title">How It Works</h2>
        <div class="how-it-works-grid">
            <div class="card">
                <h3>1. Tell Us About Your Business</h3>
                <p>Provide basic details like your industry, target audience, and the main goal of the call.</p>
            </div>
            <div class="card">
                <h3>2. AI Analyzes Your Needs</h3>
                <p>Our advanced Groq-powered AI engine drafts the perfect, high-converting script.</p>
            </div>
            <div class="card">
                <h3>3. Ready to Call</h3>
                <p>Use the generated script immediately to book appointments, close sales, or qualify leads.</p>
            </div>
        </div>

        <!-- Features -->
        <h2 class="section-title">Powerful Features</h2>
        <div class="features-grid">
            <div class="card">
                <h3>Lead Qualification</h3>
                <p>Scripts designed specifically to ask the right questions and filter high-quality leads.</p>
            </div>
            <div class="card">
                <h3>Appointment Booking</h3>
                <p>Conversational flows aimed directly at securing meetings and saving calendar slots.</p>
            </div>
            <div class="card">
                <h3>Multilingual Support</h3>
                <p>Generate precise calling scripts in English, Urdu, or Roman Urdu.</p>
            </div>
        </div>

        <!-- Blog/Content -->
        <h2 class="section-title">Why AI Calling Agents?</h2>
        <div class="blog-grid">
            <div class="card text-left">
                <h3 class="text-secondary">The Future of Sales</h3>
                <p>Cold calling isn't dead; it's evolving. AI-generated scripts remove the guesswork from outreach, providing your sales team with proven frameworks that adapt to customer pain points.</p>
            </div>
            <div class="card text-left">
                <h3 class="text-secondary">Automated Customer Support</h3>
                <p>Provide your agents with instant, empathetic responses to common customer inquiries, reducing handle times and increasing overall satisfaction.</p>
            </div>
        </div>

        <!-- Testimonials -->
        <h2 class="section-title">What Our Users Say</h2>
        <div class="testimonials-grid">
            <div class="card">
                <p class="testimonial-text">"The appointment setting scripts generated by this AI completely changed our real estate outreach. We're booking 3x more viewings."</p>
                <p class="testimonial-author">- Sarah, Apex Real Estate</p>
            </div>
            <div class="card">
                <p class="testimonial-text">"Finally, a tool that understands Roman Urdu context. Our local sales team loves the conversational flow."</p>
                <p class="testimonial-author">- Ali, Tech Solutions PK</p>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    <section class="cta-section">
        <h2>Ready to Supercharge Your Outreach?</h2>
        <p>Join hundreds of businesses using our AI to close more deals every single day.</p>
        <a href="/generator"><button class="cta-btn">Get Started for Free</button></a>
    </section>

    <%- include('partials/footer') %>

</body>
</html>