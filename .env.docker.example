# Copy this file to .env.docker and fill in your real values.
# This file is safe to commit; .env.docker should be in .gitignore.

PORT=3000

# When running with docker-compose, use the service name "mongo" as the host
MONGO_URI=mongodb://admin:admin123@mongo:27017/ecommerce-app?authSource=admin

SESSION_SECRET=replace_with_a_long_random_string
JWT_SECRET=replace_with_another_long_random_string

GROQ_API_KEY=your_groq_api_key_here
